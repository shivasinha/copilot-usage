{
  "name": "ghcp-usage-dashboard",
  "displayName": "GHCP Usage Dashboard",
  "description": "Open your GitHub Copilot usage dashboard directly from VS Code.",
  "version": "0.2.1",
  "icon": "icon.png",
  "publisher": "shiva-sinha",
  "author": "Shiva",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shivasinha/copilot-usage"
  },
  "homepage": "https://github.com/shivasinha/copilot-usage#readme",
  "bugs": {
    "url": "https://github.com/shivasinha/copilot-usage/issues"
  },
  "keywords": [
    "github-copilot",
    "copilot",
    "usage",
    "dashboard",
    "analytics",
    "tokens",
    "cost",
    "quota"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ghcpUsage.openDashboard",
        "title": "Copilot Usage: Open Dashboard"
      },
      {
        "command": "ghcpUsage.stopDashboard",
        "title": "Copilot Usage: Stop Dashboard"
      }
    ],
    "configuration": {
      "title": "GHCP Usage Dashboard",
      "properties": {
        "ghcpUsage.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Python 3.8+ executable. Leave empty to use the system PATH."
        },
        "ghcpUsage.port": {
          "type": "integer",
          "default": 8080,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Port for the local dashboard HTTP server (1024–65535)."
        },
        "ghcpUsage.autoOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the dashboard when VS Code starts."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "robocopy ..\\src resources\\src *.py /IS & tsc -p ./",
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.0.0"
  }
}
