{
  "name": "ghcp-usage-dashboard",
  "displayName": "GHCP Usage Dashboard",
  "description": "Open your GitHub Copilot usage dashboard directly from VS Code.",
  "version": "0.2.6",
  "icon": "icon.png",
  "publisher": "shivasinha",
  "author": "Shiva Sinha",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shivasinha/ghcp-usage"
  },
  "homepage": "https://github.com/shivasinha/ghcp-usage#readme",
  "bugs": {
    "url": "https://github.com/shivasinha/ghcp-usage/issues"
  },
  "keywords": [
    "github-copilot",
    "copilot",
    "usage",
    "claude",
    "dashboard",
    "analytics",
    "tokens",
    "cost",
    "quota"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "extensionKind": [
    "ui"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ghcpUsage.openDashboard",
        "title": "GHCP Usage: Open Dashboard"
      },
      {
        "command": "ghcpUsage.stopDashboard",
        "title": "GHCP Usage: Stop Dashboard"
      }
    ],
    "configuration": {
      "title": "GHCP Usage Dashboard",
      "properties": {
        "ghcpUsage.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Python 3.8+ executable. Leave empty to use the system PATH."
        },
        "ghcpUsage.port": {
          "type": "integer",
          "default": 8080,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Port for the local dashboard HTTP server (1024–65535)."
        },
        "ghcpUsage.autoOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the dashboard when VS Code starts."
        }
      }
    }
  },
  "scripts": {
    "//": [
      "── Enforced release workflow ──────────────────────────────────────────",
      "1. Update CHANGELOG.md: rename [Unreleased] → [X.Y.Z] — YYYY-MM-DD,",
      "   add a fresh [Unreleased] block, then stage the file.",
      "2. Commit all code changes (working tree must be clean before step 3).",
      "3. Run ONE of: npm run release:patch | release:minor | release:major",
      "   • preversion  – blocks if working tree is dirty (git diff --exit-code)",
      "   • version     – auto-stages CHANGELOG.md, bumps package.json, git commit + tag",
      "   • postversion – git push + git push --tags (pushes commit and tag to GitHub)",
      "   • release:*   – then builds the .vsix via vsce package",
      "4. Run: vsce publish   (uploads the .vsix to the VS Code Marketplace)",
      "───────────────────────────────────────────────────────────────────────"
    ],
    "vscode:prepublish": "robocopy ..\\src resources\\src *.py /IS & tsc -p ./",
    "compile": "tsc -p ./",
    "preversion": "git diff --exit-code",
    "version": "git add CHANGELOG.md ../CHANGELOG.md",
    "postversion": "git push && git push --tags",
    "release:patch": "npm version patch && vsce package",
    "release:minor": "npm version minor && vsce package",
    "release:major": "npm version major && vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.0.0"
  }
}
